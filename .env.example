# ─── Backend (server/ + api/) ─────────────────────────────────
# Get a free key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Model — browse https://openrouter.ai/models
#   openai/gpt-4o-mini             (cheap, smart, ~$0.15/1M tokens)
#   anthropic/claude-3.5-haiku     (cheap, fast)
#   meta-llama/llama-3.1-8b-instruct:free   (free tier)
#   google/gemini-2.0-flash-exp:free        (free tier)
OPENROUTER_MODEL=openai/gpt-4o-mini

# Your site URL (for OpenRouter analytics, optional)
SITE_URL=http://localhost:5173

# CORS — set to your GitHub Pages URL in production, e.g.
# ALLOWED_ORIGIN=https://mohammadshaireefshaikh.github.io
ALLOWED_ORIGIN=

# Local Express server port
PORT=3001

# ─── Frontend (Vite) ──────────────────────────────────────────
# Local dev: leave blank → uses Vite proxy → http://localhost:3001
# Production build: set to your Vercel URL, e.g.
# VITE_API_URL=https://your-project.vercel.app/api/chat
VITE_API_URL=
