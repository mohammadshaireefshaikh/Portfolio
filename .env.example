# ─── OpenRouter (required) ─────────────────────────────────
# Get a free key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Model to use. Browse https://openrouter.ai/models for options.
# Recommended free/cheap picks:
#   openai/gpt-4o-mini             (cheap, smart, ~$0.15/1M tokens)
#   anthropic/claude-3.5-haiku     (cheap, fast)
#   meta-llama/llama-3.1-8b-instruct:free   (free tier)
#   google/gemini-2.0-flash-exp:free        (free tier)
OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free

# Your site URL (used by OpenRouter for rankings/analytics, optional)
SITE_URL=http://localhost:5173

# ─── Server (optional) ────────────────────────────────────
PORT=3001
ALLOWED_ORIGIN=

# ─── Frontend (optional, only for production builds) ──────
# VITE_CHAT_API_URL=https://your-api-server.com/api/chat
